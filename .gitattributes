# Windows launcher scripts must keep CRLF line endings -- batch files
# with Unix (LF) endings can behave unpredictably. This guarantees the
# GitHub "Download ZIP" copy works identically to the original.
*.bat text eol=crlf
*.vbs text eol=crlf

# Everything else: normalize to LF in the repo
* text=auto
*.py text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.md text eol=lf

# Binary assets
*.png binary
*.ico binary
*.jpg binary
*.jpeg binary
